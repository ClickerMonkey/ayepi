{
  "name": "@ayepi/mock",
  "version": "0.1.0",
  "description": "Mock server for @ayepi/core — generate schema-valid fake data from a spec, with deterministic seeding and automatic pagination",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClickerMonkey/ayepi.git",
    "directory": "packages/mock"
  },
  "homepage": "https://github.com/ClickerMonkey/ayepi/tree/main/packages/mock#readme",
  "bugs": {
    "url": "https://github.com/ClickerMonkey/ayepi/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "ayepi-*.md"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "publint": "publint"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@ayepi/core": "workspace:^",
    "zod": "^4"
  },
  "devDependencies": {
    "@ayepi/core": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "publint": "^0.3.0",
    "tsdown": "^0.12.0",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "keywords": ["ayepi", "mock", "faker", "testing", "fixtures", "seed"]
}
