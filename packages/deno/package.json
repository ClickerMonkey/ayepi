{
  "name": "@ayepi/deno",
  "version": "0.1.0",
  "description": "Deno adapter for @ayepi/core — fetch-native HTTP + native WebSocket, zero dependencies",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClickerMonkey/ayepi.git",
    "directory": "packages/deno"
  },
  "homepage": "https://github.com/ClickerMonkey/ayepi/tree/main/packages/deno#readme",
  "bugs": {
    "url": "https://github.com/ClickerMonkey/ayepi/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "ayepi-*.md"],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "publint": "publint"
  },
  "engines": {
    "deno": ">=1.40.0"
  },
  "peerDependencies": {
    "@ayepi/core": "workspace:^"
  },
  "devDependencies": {
    "@ayepi/core": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "publint": "^0.3.0",
    "tsdown": "^0.12.0",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "keywords": ["ayepi", "@ayepi/core", "deno", "websocket", "adapter", "server", "fetch"]
}
