{
  "name": "@ayepi/rate",
  "version": "0.2.0",
  "description": "Rate-limiting middleware for @ayepi/core — pluggable stores, multiple algorithms, customizable 429 responses",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClickerMonkey/ayepi.git",
    "directory": "packages/rate"
  },
  "homepage": "https://github.com/ClickerMonkey/ayepi/tree/main/packages/rate#readme",
  "bugs": {
    "url": "https://github.com/ClickerMonkey/ayepi/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "ayepi-*.md"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./server": {
      "import": { "types": "./dist/server.d.ts", "default": "./dist/server.js" },
      "require": { "types": "./dist/server.d.cts", "default": "./dist/server.cjs" }
    },
    "./redis": {
      "import": { "types": "./dist/redis.d.ts", "default": "./dist/redis.js" },
      "require": { "types": "./dist/redis.d.cts", "default": "./dist/redis.cjs" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "publint": "publint"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@ayepi/core": "workspace:^",
    "ioredis": "^5"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ayepi/core": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "ioredis": "^5.4.1",
    "publint": "^0.3.0",
    "testcontainers": "^10.13.0",
    "tsdown": "^0.12.0",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "keywords": ["ayepi", "@ayepi/core", "rate-limit", "ratelimit", "middleware", "redis", "throttle"]
}
