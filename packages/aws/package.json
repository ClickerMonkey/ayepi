{
  "name": "@ayepi/aws",
  "version": "0.2.0",
  "description": "AWS backends for ayepi — an SQS @ayepi/work queue (large payloads offloaded to S3) and an S3 @ayepi/files store, all retry-wrapped for throttle resilience",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClickerMonkey/ayepi.git",
    "directory": "packages/aws"
  },
  "homepage": "https://github.com/ClickerMonkey/ayepi/tree/main/packages/aws#readme",
  "bugs": {
    "url": "https://github.com/ClickerMonkey/ayepi/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "ayepi-*.md"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./s3": {
      "import": { "types": "./dist/s3.d.ts", "default": "./dist/s3.js" },
      "require": { "types": "./dist/s3.d.cts", "default": "./dist/s3.cjs" }
    },
    "./sqs": {
      "import": { "types": "./dist/sqs.d.ts", "default": "./dist/sqs.js" },
      "require": { "types": "./dist/sqs.d.cts", "default": "./dist/sqs.cjs" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "publint": "publint"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@ayepi/core": "workspace:^",
    "@ayepi/work": "workspace:^",
    "@ayepi/files": "workspace:^",
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/client-sqs": "^3",
    "@aws-sdk/lib-storage": "^3",
    "@aws-sdk/s3-request-presigner": "^3"
  },
  "peerDependenciesMeta": {
    "@ayepi/work": { "optional": true },
    "@ayepi/files": { "optional": true },
    "@aws-sdk/client-s3": { "optional": true },
    "@aws-sdk/client-sqs": { "optional": true },
    "@aws-sdk/lib-storage": { "optional": true },
    "@aws-sdk/s3-request-presigner": { "optional": true }
  },
  "devDependencies": {
    "@ayepi/core": "workspace:*",
    "@ayepi/work": "workspace:*",
    "@ayepi/files": "workspace:*",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@vitest/coverage-v8": "^2.1.8",
    "publint": "^0.3.0",
    "testcontainers": "^10.13.0",
    "tsdown": "^0.12.0",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "keywords": ["ayepi", "aws", "sqs", "s3", "work-queue", "file-storage", "@ayepi/work", "@ayepi/files"]
}
