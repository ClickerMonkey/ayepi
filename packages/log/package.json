{
  "name": "@ayepi/log",
  "version": "0.3.0",
  "description": "Structured logging for ayepi — AsyncLocalStorage trace context, console interception, console/file transports, error serialization, middleware",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClickerMonkey/ayepi.git",
    "directory": "packages/log"
  },
  "homepage": "https://github.com/ClickerMonkey/ayepi/tree/main/packages/log#readme",
  "bugs": {
    "url": "https://github.com/ClickerMonkey/ayepi/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "ayepi-*.md"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./file": {
      "import": { "types": "./dist/file.d.ts", "default": "./dist/file.js" },
      "require": { "types": "./dist/file.d.cts", "default": "./dist/file.cjs" }
    },
    "./middleware": {
      "import": { "types": "./dist/middleware.d.ts", "default": "./dist/middleware.js" },
      "require": { "types": "./dist/middleware.d.cts", "default": "./dist/middleware.cjs" }
    },
    "./server": {
      "import": { "types": "./dist/server.d.ts", "default": "./dist/server.js" },
      "require": { "types": "./dist/server.d.cts", "default": "./dist/server.cjs" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "publint": "publint"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@ayepi/core": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@ayepi/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ayepi/core": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "publint": "^0.3.0",
    "tsdown": "^0.12.0",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "keywords": ["ayepi", "logging", "logger", "structured-logging", "async-local-storage", "tracing", "middleware"]
}
