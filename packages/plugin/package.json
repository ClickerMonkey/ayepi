{
  "name": "@ayepi/plugin",
  "version": "0.0.0",
  "description": "A plugin system for @ayepi/core — compose an API from independent plugins (spec + implementation + state service + lifecycle + deps) and install/uninstall them into a running server",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "publint": "publint"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@ayepi/core": "workspace:^"
  },
  "devDependencies": {
    "@ayepi/core": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "publint": "^0.3.0",
    "tsdown": "^0.12.0",
    "vitest": "^2.1.8",
    "zod": "^4.4.3"
  },
  "keywords": ["ayepi", "plugin", "modular", "plugins", "lifecycle", "dependency-injection", "hot-reload"]
}
