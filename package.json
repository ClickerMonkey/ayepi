{
  "name": "ayepi-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "smoke": "pnpm --filter @ayepi/core smoke",
    "lint": "eslint \"packages/**/*.ts\" && node scripts/check-casts.mjs",
    "lint:fix": "eslint \"packages/**/*.ts\" --fix",
    "attw": "pnpm -r attw",
    "publint": "pnpm -r publint",
    "version:show": "node scripts/version.mjs",
    "version:set": "node scripts/version.mjs",
    "publish:all": "pnpm -r publish --access public --no-git-checks",
    "release:dry": "pnpm -r build && pnpm -r publint && pnpm -r publish --dry-run --no-git-checks",
    "release": "pnpm -r build && pnpm -r publint && pnpm run publish:all"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.18.0"
  }
}
